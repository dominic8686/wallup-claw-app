# LXC host IP — machine-specific, used to build token server URL for tablets
CT200_HOST=192.168.x.x

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=<min 32 chars — generate with: openssl rand -hex 32>

# OpenRouter — LLM (all modes) and STT transcription
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI — used when TTS_BACKEND=openai in docker-compose.yml
OPENAI_API_KEY=sk-your-openai-key-here

# Google API key (required for Gemini Live realtime model)
GOOGLE_API_KEY=

# --- All other config lives in docker-compose.yml ---
# --- Additional secrets (HASS_TOKEN, etc.) go in ~/.hermes/.env ---
