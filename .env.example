# LXC host IP — used to build LIVEKIT_EXTERNAL_URL for tablets
CT200_HOST=192.168.211.153

# LiveKit Server — infrastructure vars, specific to this project
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=<min 32 chars — generate with: openssl rand -hex 32>

# Agent mode
# AGENT_MODE=hermes      Full Hermes AIAgent: tools, memory, HA, MCP (default)
# AGENT_MODE=openrouter  Lightweight direct OpenRouter call, no tools
AGENT_MODE=hermes

# Model used in openrouter mode only (ignored in hermes mode)
# Examples: openai/gpt-4o-mini  google/gemini-2.0-flash  anthropic/claude-3-haiku
AGENT_MODEL=openai/gpt-4o-mini

# --- All other API keys go in ~/.hermes/.env on the LXC host, NOT here ---
# OpenAI, OpenRouter, HASS token, Browserbase, Firecrawl, Telegram, Discord, etc.
# are loaded at runtime via load_dotenv('~/.hermes/.env') from the mounted volume.
# See /opt/hermes/.env.example on the LXC for a full template.
